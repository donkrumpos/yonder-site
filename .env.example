# Supabase — public-safe values, shipped to the browser.
# Get these from Project Settings → API in the Supabase dashboard.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Cloudflare Turnstile — public site key (the secret key lives in Supabase
# Edge Function Secrets as TURNSTILE_SECRET_KEY).
PUBLIC_TURNSTILE_SITE_KEY=

# Stripe (shop checkout)
PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ────────────────────────────────────────────────────────────────────────────
# Secrets that DON'T belong here:
#   RESEND_API_KEY, FROM_EMAIL, SUPABASE secret/service_role,
#   STRIPE_SECRET_KEY, etc.
# Those are stored as Supabase Edge Function Secrets (Project → Edge Functions
# → Secrets) and accessed via Deno.env.get() inside the edge functions.
# Same pattern as DCLT.
