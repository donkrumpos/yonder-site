---
// Subscribe form — POSTs to the `subscribe` Supabase Edge Function with a
// Cloudflare Turnstile token. Designed to support multiple instances on the
// same page (e.g. footer + page-body CTA), so it uses classes rather than
// ids for everything the script touches.
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<form class="yonder-subscribe-form flex flex-col gap-3" novalidate>
  <div class="flex flex-col sm:flex-row gap-2">
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      aria-label="Email"
      placeholder="your@email.com"
      class="flex-1 bg-transparent border border-yonder-ink-600 px-3 py-2 text-yonder-bone-200 placeholder-yonder-bone-500 focus:outline-none focus:border-yonder-brass"
    />
    <!-- Honeypot — hidden from humans, attractive to bots -->
    <input
      type="text"
      name="website"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      class="absolute left-[-9999px] w-px h-px opacity-0"
    />
    <button
      type="submit"
      class="bg-yonder-brass text-yonder-ink-950 px-4 py-2 font-display uppercase tracking-wider text-sm hover:bg-yonder-bone-200 transition-colors disabled:opacity-50"
    >
      Subscribe
    </button>
  </div>
  <div
    class="cf-turnstile"
    data-sitekey={turnstileSiteKey}
    data-theme="dark"
    data-size="flexible"
  ></div>
  <p
    class="yonder-subscribe-status mt-2 text-sm text-yonder-bone-500 min-h-[1.25rem]"
    aria-live="polite"
  ></p>
</form>

<script
  is:inline
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer></script>

<script>
  import { createClient } from '@supabase/supabase-js';

  const url = import.meta.env.PUBLIC_SUPABASE_URL;
  const key = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY;

  if (!url || !key) {
    console.error('Missing PUBLIC_SUPABASE_URL or PUBLIC_SUPABASE_PUBLISHABLE_KEY');
  }

  const supabase = createClient(url, key);

  document
    .querySelectorAll<HTMLFormElement>('.yonder-subscribe-form')
    .forEach(setupForm);

  function setupForm(form: HTMLFormElement) {
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const statusEl = form.querySelector<HTMLElement>('.yonder-subscribe-status');
    const turnstileEl = form.querySelector<HTMLElement>('.cf-turnstile');
    if (!button || !statusEl) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const email = String(data.get('email') ?? '').trim();
      const website = String(data.get('website') ?? '');
      const turnstileToken = String(data.get('cf-turnstile-response') ?? '');

      if (!email || !email.includes('@')) {
        setStatus(statusEl, 'Please enter a valid email.', 'error');
        return;
      }
      if (!turnstileToken) {
        setStatus(statusEl, 'Please wait for the security check to finish, then try again.', 'error');
        return;
      }

      button.disabled = true;
      setStatus(statusEl, 'Sending…', 'pending');

      const { data: result, error } = await supabase.functions.invoke('subscribe', {
        body: {
          email,
          website,
          turnstile_token: turnstileToken,
          source: window.location.pathname || '/',
        },
      });

      button.disabled = false;

      // Reset just THIS form's Turnstile widget — tokens are single-use.
      const turnstile = (window as any).turnstile;
      if (turnstile?.reset && turnstileEl) turnstile.reset(turnstileEl);

      if (error) {
        console.error(error);
        setStatus(statusEl, "Couldn't subscribe right now — try again in a minute?", 'error');
        return;
      }

      if (result?.alreadyConfirmed) {
        setStatus(statusEl, "You're already on the list — thank you.", 'ok');
        form.reset();
      } else {
        setStatus(statusEl, "Check your email — we sent a confirmation link.", 'ok');
        form.reset();
      }
    });
  }

  function setStatus(el: HTMLElement, msg: string, kind: 'ok' | 'error' | 'pending') {
    el.textContent = msg;
    el.className =
      'yonder-subscribe-status mt-2 text-sm min-h-[1.25rem] ' +
      (kind === 'ok'
        ? 'text-yonder-brass'
        : kind === 'error'
        ? 'text-red-400'
        : 'text-yonder-bone-500');
  }
</script>
