---
import Base from '@layouts/Base.astro';
import SubscribeForm from '@components/forms/SubscribeForm.astro';
---

<Base
  title="Krampusnacht 2026 — Yonder Art Land"
  description="Four nights of immersive theater in Algoma, Wisconsin. December 4–5 and December 11–12, 2026. Thirty seats per showing."
>
  <section class="px-6 py-24 max-w-3xl mx-auto">
    <p class="text-xs uppercase tracking-widest text-yonder-brass mb-4">
      Krampusnacht 2026
    </p>
    <h1 class="font-display text-4xl md:text-6xl mb-6">
      Four nights. Thirty seats each.
    </h1>
    <div class="font-serif text-lg text-yonder-bone-300 space-y-4 mb-12">
      <p>
        December 4 and 5. December 11 and 12. Algoma, Wisconsin.
      </p>
      <p>
        The third Krampusnacht in seven years. Built off-site over months.
        Deployed into the studio for two weeks. Witnessed in person, then
        struck.
      </p>
      <p class="text-sm text-yonder-bone-500">
        Tickets launch September 1, 2026. Subscribers get the link first.
      </p>
    </div>
    <SubscribeForm />
  </section>
</Base>
