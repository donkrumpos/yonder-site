---
import Base from '@layouts/Base.astro';
import ContactForm from '@components/forms/ContactForm.astro';
---

<Base title="Contact — Yonder Art Land">
  <section class="px-6 py-16 max-w-2xl mx-auto">
    <h1 class="font-display text-4xl mb-8">Contact</h1>
    <div class="font-serif text-lg text-yonder-bone-300 space-y-2 mb-12">
      <p>321 Steele Street, Algoma, WI 54201</p>
      <p>
        <a href="tel:9202644325" class="hover:text-yonder-brass">
          920-264-4325
        </a>
      </p>
    </div>
    <h2 class="font-display text-2xl uppercase tracking-wider text-yonder-bone-200 mb-6">
      Send a note
    </h2>
    <ContactForm />
  </section>
</Base>
