---
import Base from '@layouts/Base.astro';
---

<Base>
  <section class="px-6 py-24 max-w-4xl mx-auto">
    <p class="text-xs uppercase tracking-widest text-yonder-brass mb-4">
      Coming this December
    </p>
    <h1 class="font-display text-5xl md:text-7xl mb-6">
      Krampusnacht 2026
    </h1>
    <p class="font-serif text-xl text-yonder-bone-300 max-w-2xl mb-8">
      Four nights. Thirty seats each. Algoma, Wisconsin.
      The third Krampusnacht in seven years — built in the basement,
      summoned in the studio.
    </p>
    <a
      href="/krampusnacht-2026"
      class="inline-block bg-yonder-brass text-yonder-ink-950 px-6 py-3 font-display uppercase tracking-wider text-sm hover:bg-yonder-bone-200 transition-colors"
    >
      Get on the list
    </a>
  </section>

  <section class="px-6 py-16 max-w-4xl mx-auto border-t border-yonder-ink-700">
    <h2 class="font-display text-3xl mb-6">What is Yonder</h2>
    <div class="font-serif text-lg text-yonder-bone-300 space-y-4">
      <p>
        A studio and a world in Algoma, Wisconsin. Murals across the Midwest,
        prints and candles in the shop, performances in the cabinet of the
        wilding hours.
      </p>
      <p>
        Anti-plastic, pro-handcraft. Everything intentional, nothing
        mass-produced.
      </p>
    </div>
  </section>

  <section class="px-6 py-16 max-w-4xl mx-auto border-t border-yonder-ink-700">
    <h2 class="font-display text-3xl mb-6">Projects</h2>
    <p class="text-yonder-bone-300 mb-6">
      Forty-plus murals, exhibits, performances, and workshops since 2018.
    </p>
    <a href="/projects" class="text-yonder-brass hover:underline">
      Browse the archive →
    </a>
    {/* Project grid placeholder — migrate from yonder-reference */}
  </section>
</Base>
